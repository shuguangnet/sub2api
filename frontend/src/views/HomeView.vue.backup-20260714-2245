      const target = ((i + 1) / introLines.length) * 100
      animateNumber(introProgress.value, target, 360, (v) => (introProgress.value = v))
    }, 300 + i * lineDur)
    introTimers.push(tm2)
  })
  const total = 300 + introLines.length * lineDur + 380
  const tmEnd = setTimeout(() => {
    introDone.value = true
    const tmHide = setTimeout(() => { introVisible.value = false }, 700)
    introTimers.push(tmHide)
  }, total)
  introTimers.push(tmEnd)
}

// ===== 动效：数字计数 =====
const animatedUptime = ref(0)
const animatedModels = ref(0)
const animatedLatency = ref(0)
const latencyMs = ref(642)

function animateNumber(from: number, to: number, duration: number, onUpdate: (v: number) => void, decimals = 0) {
  const state = { value: from }
  return gsap.to(state, {
    value: to,
    duration: duration / 1000,
    ease: 'power3.out',
    onUpdate: () => {
      onUpdate(decimals > 0 ? Number(state.value.toFixed(decimals)) : Math.round(state.value))
    }
  })
}

// ===== 动效：打字机模型名 =====
const typedModel = ref('')
const modelCycle = ['claude-sonnet', 'gpt-4o', 'gemini-1.5-pro', 'claude-opus', 'grok-2']
let modelIdx = 0
let typeTimer: ReturnType<typeof setTimeout> | null = null
function typeNextModel() {
  const target = modelCycle[modelIdx % modelCycle.length]
  let i = 0
  typedModel.value = ''
  const tick = () => {
    if (i <= target.length) {
      typedModel.value = target.slice(0, i)
      i++
      typeTimer = setTimeout(tick, 65)
    } else {
      typeTimer = setTimeout(() => {
        modelIdx++
        typeNextModel()
      }, 1800)
    }
  }
  tick()
}

// ===== 动效：延迟波动 =====
let latencyTimer: ReturnType<typeof setInterval> | null = null
function startLatencyJitter() {
  latencyTimer = setInterval(() => {
    latencyMs.value = 380 + Math.floor(Math.random() * 420)
  }, 1500)
}

// ===== 动效：波形 + 预览数据 =====
const animatedBalance = ref(0)
const requestsToday = ref(0)
const barHeights = ref<number[]>(Array.from({ length: 28 }, () => 30 + Math.random() * 55))
const modelChips = [
  { id: 'claude-sonnet', name: 'Claude', color: 'chip-orange' },
  { id: 'gpt-4o', name: 'GPT-4o', color: 'chip-emerald' },
  { id: 'gemini-1.5-pro', name: 'Gemini', color: 'chip-blue' },
  { id: 'grok-2', name: 'Grok', color: 'chip-zinc' },
  { id: 'claude-opus', name: 'Opus', color: 'chip-violet' }
]
let barTimer: ReturnType<typeof setInterval> | null = null
function startBars() {
  barTimer = setInterval(() => {
    barHeights.value = barHeights.value.map((h) => Math.max(15, Math.min(95, h + (Math.random() - 0.5) * 26)))
  }, 900)
}

// ===== GSAP motion system =====
function initGsapAnimations(reduceMotion: boolean) {
  if (!homeRoot.value) return

  if (reduceMotion) {
    gsap.set(homeRoot.value.querySelectorAll('.reveal, .reveal-on-scroll'), { autoAlpha: 1, y: 0 })
    return
  }

  gsapContext = gsap.context(() => {
    const heroTimeline = gsap.timeline({
      defaults: { ease: 'power3.out' },
      delay: introVisible.value ? 2.15 : 0.05
    })
    heroTimeline
      .from('.nav-bar', { autoAlpha: 0, y: -18, duration: 0.65 })
      .from('.hero-eyebrow', { autoAlpha: 0, y: 20, duration: 0.55 }, '-=0.2')
      .from('.hero-title', { autoAlpha: 0, y: 54, rotateX: -8, transformOrigin: '50% 100%', duration: 1.05 }, '-=0.3')
      .from('.hero-sub', { autoAlpha: 0, y: 28, duration: 0.7 }, '-=0.55')
      .from(['.hero-actions', '.hero-assurances'], { autoAlpha: 0, y: 20, duration: 0.6, stagger: 0.1 }, '-=0.38')
      .from('.gateway-console', { autoAlpha: 0, y: 34, scale: 0.985, duration: 0.85 }, '-=0.3')

    gsap.set('.reveal-on-scroll', { autoAlpha: 0, y: 34 })
    ScrollTrigger.batch('.reveal-on-scroll', {
      start: 'top 88%',
      once: true,
      onEnter: (elements) => {
        gsap.to(elements, {
          autoAlpha: 1,
          y: 0,
          duration: 0.82,
          stagger: 0.08,
          ease: 'power3.out',
          overwrite: true
        })
      }
    })

    const stats = { uptime: 0, models: 0, latency: 0 }
    gsap.to(stats, {
      uptime: 99.9,
      models: 20,
      latency: 642,
      duration: 1.5,
      ease: 'power3.out',
      scrollTrigger: { trigger: '.manifesto-stats', start: 'top 86%', once: true },
      onUpdate: () => {
        animatedUptime.value = Number(stats.uptime.toFixed(1))
        animatedModels.value = Math.round(stats.models)
        animatedLatency.value = Math.round(stats.latency)
      }
    })

    heroOrbX = gsap.quickTo('.hero-orb', 'x', { duration: 1.1, ease: 'power3.out' })
    heroOrbY = gsap.quickTo('.hero-orb', 'y', { duration: 1.1, ease: 'power3.out' })

    animationMedia = gsap.matchMedia()
    animationMedia.add('(min-width: 768px)', () => {
      gsap.to('.hero-copy', {
        yPercent: -9,
        ease: 'none',
        scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 0.8 }
      })
      gsap.to('.orb-1', {
        y: 150,
        x: -40,
        ease: 'none',
        scrollTrigger: { trigger: '.home-shell', start: 'top top', end: 'bottom bottom', scrub: 1.2 }
      })
      gsap.to('.orb-2', {
        y: -130,
        x: 36,
        ease: 'none',
        scrollTrigger: { trigger: '.home-shell', start: 'top top', end: 'bottom bottom', scrub: 1.2 }
      })
    })
  }, homeRoot.value)

  requestAnimationFrame(() => ScrollTrigger.refresh())
}

function initTheme() {
  const savedTheme = localStorage.getItem('theme')
  if (savedTheme === 'dark' || (!savedTheme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
    isDark.value = true
    document.documentElement.classList.add('dark')
  }
}

onMounted(() => {
  initTheme()
  authStore.checkAuth()
  if (!appStore.publicSettingsLoaded) appStore.fetchPublicSettings()

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  if (reduceMotion) {
    introVisible.value = false
  } else {
    runIntro()
  }

  animateNumber(0, 128.4, 1200, (v) => (animatedBalance.value = v), 2)
  animateNumber(0, 1284, 1200, (v) => (requestsToday.value = v))
  typeNextModel()
  startLatencyJitter()
  startBars()
  initGsapAnimations(reduceMotion)
})

onUnmounted(() => {
  if (typeTimer) clearTimeout(typeTimer)
  if (latencyTimer) clearInterval(latencyTimer)
  if (barTimer) clearInterval(barTimer)
  animationMedia?.revert()
  gsapContext?.revert()
  heroOrbX = null
  heroOrbY = null
  introTimers.forEach((tm) => clearTimeout(tm))
})
</script>

